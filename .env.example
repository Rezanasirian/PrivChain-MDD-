# ─────────────────────────────────────────────────────────────────────────────
# PrivChain-MDD environment template.
# Copy to `.env` (which is git-ignored) and fill in real values locally.
# NEVER commit a populated .env — see CLAUDE.md §7.
# ─────────────────────────────────────────────────────────────────────────────

# --- Data ---
# Absolute or repo-relative path to the (access-controlled) DAIC-WOZ dataset.
# Leave empty to run against generated mock data only.
DAIC_WOZ_ROOT=
# Path where generated mock data is written (Phase 0).
MOCK_DATA_ROOT=data/mock

# --- Reproducibility ---
GLOBAL_SEED=42

# --- Hyperledger Fabric (used from Phase 5 onward) ---
FABRIC_NETWORK_PROFILE=
FABRIC_CHANNEL=privchain-channel
FABRIC_CHAINCODE_NAME=privchain-cc
FABRIC_MSP_ID=
FABRIC_PEER_ENDPOINT=
FABRIC_GATEWAY_PEER=
# Paths to identity material — files themselves live outside the repo.
FABRIC_CERT_PATH=
FABRIC_KEY_PATH=
FABRIC_TLS_CERT_PATH=

# --- Experiment tracking (optional) ---
# If set, runs log to this MLflow server; otherwise the experiments/ folder
# structure is used as the minimum standard (see CLAUDE.md §3).
MLFLOW_TRACKING_URI=
